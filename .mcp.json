{
  "mcpServers": {
    "jira": {
      "type": "stdio",
      "command": "bash",
      "args": ["tools/jira-mcp/run-mcp.sh"],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp", "-E", "build", "test", "devserver", "modernize"]
    }
  }
}
